@model IEnumerable<SmartShop.Models.Product>
@{
    ViewData["Title"] = "SmartShop - Smart Store";
}

<!-- Section-->
<section class="py-5">
    <div class="container px-4 px-lg-5 mt-5">
        <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
            @foreach (var product in Model)
            {
                <div class="col mb-5">
                    <div class="card h-100 shadow-sm">
                        <!-- Product image-->
                        <img class="card-img-top" src="@product.ImageUrl" alt="@product.Title" 
                             style="height: 200px; object-fit: cover;"/>
                        
                        <!-- Product details-->
                        <div class="card-body p-4">
                            <div class="text-center">
                                <!-- Product name-->
                                <h5 class="fw-bolder">@product.Title</h5>
                                <!-- Product description -->
                                <p class="text-muted small mt-2">@product.Description</p>
                                <!-- Product price-->
                                <span class="fw-bold text-primary fs-5">$@product.Price</span>
                            </div>
                        </div>
                        
                        <!-- Product actions-->
                        <div class="card-footer p-3 border-top-0 bg-transparent">
                            <!-- Add To Cart Button -->
                            <form asp-controller="Products" asp-action="AddToCart" method="post" class="mb-2">
                                <input type="hidden" name="productId" value="@product.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-dark w-100">
                                    <i class="bi-cart-fill me-1"></i> 
                                    Add To Cart
                                </button>
                            </form>

                            <!-- Admin Buttons -->
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Update" asp-controller="Products" asp-route-id="@product.Id" 
                                   class="btn btn-sm btn-outline-primary rounded-circle" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <form asp-action="Delete" asp-controller="Products" asp-route-id="@product.Id" 
                                      method="post" class="d-inline" 
                                      onsubmit="return confirm('Are you sure you want to delete this product?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Bootstrap Icons CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

<!-- TempData Messages -->
@if (TempData["Success"] != null)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show align-items-center text-white bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    @TempData["Success"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div class="toast show align-items-center text-white bg-danger border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    @TempData["Error"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Auto-hide toast messages after 5 seconds
        document.addEventListener('DOMContentLoaded', function() {
            var toasts = document.querySelectorAll('.toast');
            toasts.forEach(function(toast) {
                setTimeout(function() {
                    var bsToast = new bootstrap.Toast(toast);
                    bsToast.hide();
                }, 5000);
            });
        });
    </script>
}